/**
 * ============================================================
 * Plant Vital Monitoring System
 * LDC1101 Inductance Sensor — Teensy 4.0 Firmware
 * ============================================================
 * 
 * Description:
 *   Reads high-resolution inductive sensor data from the LDC1101
 *   via SPI. Timestamps every reading using HW-689 RTC via I²C.
 *   Logs data to MicroSD card in text format and streams it
 *   wirelessly over Bluetooth (BT05 module on Serial1).
 *
 * Hardware:
 *   - Teensy 4.0 (central MCU)
 *   - LDC1101 inductance sensor PCB (SPI)
 *   - HW-689 RTC module — PCF8563 (I²C)
 *   - MicroSD Card Adapter (SPI)
 *   - BT05 Bluetooth Module (UART via Serial1)
 *
 * Pin Connections:
 *   LDC1101:
 *     VDD       → 3.3V
 *     GND       → GND
 *     SDO/INTB  → MISO (Pin 12)
 *     SCLK      → SCK  (Pin 13)
 *     SDI       → MOSI (Pin 11)
 *     CSB       → Pin 10
 *
 *   MicroSD:
 *     VCC  → 5V
 *     GND  → GND
 *     MISO → Pin 12
 *     MOSI → Pin 11
 *     SCK  → Pin 13
 *     CS   → Pin 9
 *
 *   RTC HW-689:
 *     VCC → 3.3V
 *     GND → GND
 *     SCL → SCL0 (Pin 19)
 *     SDA → SDA0 (Pin 18)
 *
 *   BT05:
 *     VCC → 5V
 *     GND → GND
 *     TXD → RX1 (Pin 0)
 *     RXD → TX1 (Pin 1)
 *
 * Libraries:
 *   - SPI.h      (built-in)
 *   - Wire.h     (built-in)
 *   - SdFat      by Bill Greiman
 *   - RTClib     by Adafruit
 *
 * TU Chemnitz — Project Lab Embedded Systems — Group 11
 * Date: 2025-07-09
 * ============================================================
 */

#include <SPI.h>
#include <SdFat.h>
#include <Wire.h>
#include "RTClib.h"

// ─────────────────────────────────────────────
// Hardware Pin Definitions
// ─────────────────────────────────────────────
const int chipSelect_SDCard = 9;   // CS pin for MicroSD card
const int CS_PIN_LDC        = 10;  // CS pin for LDC1101

// ─────────────────────────────────────────────
// Peripheral Objects
// ─────────────────────────────────────────────
SdFat SD;                          // SD card file system object
RTC_PCF8563 rtc;                   // RTC object (HW-689 uses PCF8563 chip)

// ─────────────────────────────────────────────
// Aliases & Defines
// ─────────────────────────────────────────────
#define BTSerial  Serial1          // Bluetooth via Serial1 (pins 0 and 1)
#define READ_REG  0x80             // SPI read flag: bit7 = 1
#define WRITE_REG 0x00             // SPI write flag: bit7 = 0

// ─────────────────────────────────────────────
// LDC1101 Register Map (key registers)
// ─────────────────────────────────────────────
#define REG_RPMIN       0x01   // Minimum RP value
#define REG_START_CFG   0x0B   // Start configuration / sleep mode
#define REG_ALT_CONFIG  0x05   // Alternate configuration (LOPTIMAL)
#define REG_D_CONFIG    0x0C   // D configuration (DOK_REPORT)
#define REG_FREQ_DIV    0x34   // Sensor frequency divider
#define REG_LHR_RCOUNT_LSB 0x30
#define REG_LHR_RCOUNT_MSB 0x31
#define REG_LHR_OFFSET_LSB 0x32
#define REG_LHR_OFFSET_MSB 0x33
#define REG_LHR_DATA_LSB   0x38
#define REG_LHR_DATA_MID   0x39
#define REG_LHR_DATA_MSB   0x3A
#define REG_LHR_STATUS     0x3B
#define REG_POR_STATUS     0x20   // Power-On Reset status

// ─────────────────────────────────────────────
// SPI Write: write 1 byte to LDC1101 register
// ─────────────────────────────────────────────
void writeRegister_LDC(uint8_t reg, uint8_t value) {
  digitalWrite(CS_PIN_LDC, LOW);                   // Select LDC1101
  SPI.transfer(WRITE_REG | (reg & 0x3F));           // Write command + address (max 0x3F)
  SPI.transfer(value);                              // Data byte
  digitalWrite(CS_PIN_LDC, HIGH);                  // Deselect LDC1101
}

// ─────────────────────────────────────────────
// SPI Read: read 1 byte from LDC1101 register
// ─────────────────────────────────────────────
uint8_t readRegister_LDC(uint8_t reg) {
  digitalWrite(CS_PIN_LDC, LOW);                   // Select LDC1101
  SPI.transfer(READ_REG | (reg & 0x3F));            // Read command + address
  uint8_t val = SPI.transfer(0x00);                // Clock out data (send dummy byte)
  digitalWrite(CS_PIN_LDC, HIGH);                  // Deselect LDC1101
  return val;
}

// ─────────────────────────────────────────────
// Configure LDC1101 in LHR (L High Resolution) Mode
// ─────────────────────────────────────────────
void LHR_modeSetup() {
  SPI.begin();
  SPI.beginTransaction(SPISettings(1000000, MSBFIRST, SPI_MODE0));
  // 1 MHz clock, MSB first, Mode 0 (CPOL=0, CPHA=0)

  pinMode(CS_PIN_LDC, OUTPUT);
  digitalWrite(CS_PIN_LDC, HIGH);                  // Start with LDC deselected

  // Wait for Power-On Reset to complete (POR_STATUS bit0 must be 0)
  while (readRegister_LDC(REG_POR_STATUS) & 0x01) {
    delay(10);
  }

  // Step 1: Enter Sleep Mode before configuring registers
  writeRegister_LDC(REG_START_CFG, 0x01);          // Sleep mode ON

  // Step 2: Set minimum RP value
  writeRegister_LDC(REG_RPMIN, 0x05);              // RPMIN = 3 kΩ

  // Step 3: Sensor frequency divider (no division)
  writeRegister_LDC(REG_FREQ_DIV, 0x00);           // Default: not divided

  // Step 4: Set LHR_RCOUNT to 0xFFFF for maximum resolution
  writeRegister_LDC(REG_LHR_RCOUNT_LSB, 0xFF);
  writeRegister_LDC(REG_LHR_RCOUNT_MSB, 0xFF);

  // Step 5: Set LHR offset to 0x0000
  writeRegister_LDC(REG_LHR_OFFSET_LSB, 0x00);
  writeRegister_LDC(REG_LHR_OFFSET_MSB, 0x00);

  // Step 6: Enable L-Optimal mode (ALT_CONFIG register, bit0)
  writeRegister_LDC(REG_ALT_CONFIG, 0x01);         // LOPTIMAL = 1

  // Step 7: Enable DOK_REPORT in D_CONFIG (bit0)
  writeRegister_LDC(REG_D_CONFIG, 0x01);           // DOK_REPORT = 1

  // Step 8: Exit Sleep Mode → Enter Conversion Mode
  writeRegister_LDC(REG_START_CFG, 0x00);

  Serial.println("[LDC1101] LHR Mode Setup Completed");
}

// ─────────────────────────────────────────────
// Read 24-bit LHR Data from LDC1101
// ─────────────────────────────────────────────
uint32_t read_LHR_Data() {
  SPI.beginTransaction(SPISettings(1000000, MSBFIRST, SPI_MODE0));

  // Poll LHR_STATUS register until data is ready (bit0 = 0 means ready)
  while (readRegister_LDC(REG_LHR_STATUS) & 0x01) {
    // bit0 = 1 → conversion in progress, wait
  }

  // Read 3 bytes of LHR data
  uint8_t lsb = readRegister_LDC(REG_LHR_DATA_LSB);
  uint8_t mid = readRegister_LDC(REG_LHR_DATA_MID);
  uint8_t msb = readRegister_LDC(REG_LHR_DATA_MSB);

  // Combine into 24-bit value
  uint32_t lhrValue = ((uint32_t)msb << 16) | ((uint32_t)mid << 8) | lsb;
  return lhrValue;
}

// ─────────────────────────────────────────────
// Initialize MicroSD Card
// ─────────────────────────────────────────────
void SDcard_setup() {
  pinMode(chipSelect_SDCard, OUTPUT);
  digitalWrite(chipSelect_SDCard, HIGH);            // SD card deselected initially

  // Initialize SD at 10 MHz SPI
  if (!SD.begin(chipSelect_SDCard, SD_SCK_MHZ(10))) {
    Serial.println("[SD] Card failed or not present! Halting.");
    while (1);                                      // Stop execution if SD fails
  }
  Serial.println("[SD] Card initialized successfully.");
}

// ─────────────────────────────────────────────
// Setup
// ─────────────────────────────────────────────
void setup() {
  Serial.begin(9600);
  while (!Serial);                                  // Wait for Serial Monitor

  // Initialize Bluetooth serial
  BTSerial.begin(9600);                             // BT05 default baud rate
  Serial.println("[BT] Bluetooth UART ready on Serial1");

  // Initialize I²C for RTC
  Wire.begin();

  // Initialize RTC
  if (!rtc.begin()) {
    Serial.println("[RTC] Could not find HW-689 RTC! Check wiring.");
    while (1);
  }

  // Set initial date/time — comment out after first upload
  rtc.adjust(DateTime(2025, 6, 29, 13, 25, 0));
  Serial.println("[RTC] RTC initialized and running.");

  // Initialize SD card
  SDcard_setup();

  // Initialize and configure LDC1101
  LHR_modeSetup();

  Serial.println("\n[SYSTEM] All peripherals initialized. Starting data acquisition...\n");
}

// ─────────────────────────────────────────────
// Main Loop
// ─────────────────────────────────────────────
void loop() {
  // Read LHR sensor value
  uint32_t lhrValue = read_LHR_Data();

  // Get current timestamp from RTC
  DateTime now = rtc.now();

  // Build timestamp string
  String timeStr = String(now.hour()) + ":" + String(now.minute()) + ":" + String(now.second());
  String dateStr = String(now.day()) + "/" + String(now.month()) + "/" + String(now.year());

  // Build full data string
  String dataLine = "LHRData: " + String(lhrValue) +
                    "  Time: " + timeStr +
                    "  Date: " + dateStr;

  // Print to USB Serial Monitor
  Serial.println(dataLine);

  // Send to Bluetooth (mobile app)
  BTSerial.println("LHRData: " + String(lhrValue));

  // ── Write to SD Card ──────────────────────
  FsFile file = SD.open("Data7.txt", FILE_WRITE);
  if (file) {
    file.println(dataLine);
    file.close();
  } else {
    Serial.println("[SD] ERROR: Failed to open file for writing.");
  }

  delay(1000);   // 1 reading per second

  // ── Read back from SD Card (for verification) ──
  file = SD.open("Data7.txt", FILE_READ);
  if (file) {
    Serial.println("\n===== SD Card Data =====");
    while (file.available()) {
      Serial.write(file.read());
    }
    file.close();
    Serial.println("===== SD Card END =====\n");
  } else {
    Serial.println("[SD] ERROR: Failed to open file for reading.");
  }
}
